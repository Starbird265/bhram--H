{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cortex AI",
  "version": "0.1.0",
  "identifier": "com.bhrm.cortex-ai",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": "http://localhost:8000"
  },
  "app": {
    "windows": [
      {
        "title": "Cortex AI — Organizational Intelligence",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' http://localhost:8000 http://127.0.0.1:8000"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "python-backend",
          "cmd": "python3",
          "args": true
        }
      ]
    }
  }
}
