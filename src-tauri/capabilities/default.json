{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Cortex AI default permissions — core, shell, and logging",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill"
  ]
}
